# Copy to the environment-specific file expected by the final Expo setup.
# Only variables prefixed EXPO_PUBLIC_ are bundled into the client.
# Never put service-role or external provider secret keys in a mobile env file.

EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace_with_local_anon_key

# Optional non-secret feature configuration
EXPO_PUBLIC_ENABLE_SCORE_INSPECTOR=true

# Server-side secrets belong in Supabase local function env / secret storage:
# PLACE_PROVIDER_API_KEY=
# WEATHER_PROVIDER_API_KEY=
# ROUTING_PROVIDER_API_KEY=
# LLM_PROVIDER_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
